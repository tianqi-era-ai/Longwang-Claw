{
  "id": "star-office-sync",
  "name": "Star Office Sync",
  "description": "Lightweight Star Office UI state sync for main-agent lifecycle, key tool phases, and chat commands.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "repoPath": { "type": "string" },
      "stateFile": { "type": "string" },
      "enabledForAgentIds": {
        "type": "array",
        "items": { "type": "string" }
      },
      "minUpdateMs": { "type": "number", "minimum": 0 },
      "backendPort": { "type": "number", "minimum": 1, "maximum": 65535 },
      "cloudflaredBin": { "type": "string" },
      "busyDetail": { "type": "string" },
      "idleDetail": { "type": "string" },
      "researchingDetail": { "type": "string" },
      "executingDetail": { "type": "string" },
      "writingDetail": { "type": "string" },
      "errorDetail": { "type": "string" }
    }
  }
}

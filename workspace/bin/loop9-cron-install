#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from pathlib import Path

WORKSPACE = Path('~/.openclaw/workspace').expanduser()
JOBS_PATH = WORKSPACE / 'plans' / 'loop9-hourly-cron-jobs.example.json'


def load_jobs() -> dict:
    return json.loads(JOBS_PATH.read_text(encoding='utf-8'))


def main() -> int:
    parser = argparse.ArgumentParser(description='Prepare disabled Loop9 hourly cron job definitions.')
    parser.add_argument('--json', action='store_true', help='Print JSON only (default behavior).')
    parser.add_argument('--summary', action='store_true', help='Print a short human summary.')
    ns = parser.parse_args()

    payload = load_jobs()

    if ns.summary:
        print('Loop9 hourly cron definitions (all disabled by default):')
        for job in payload.get('jobs', []):
            schedule = job.get('schedule', {})
            print(f"- {job.get('name')} :: {schedule.get('expr')} :: enabled={job.get('enabled')}")
        return 0

    print(json.dumps(payload, ensure_ascii=False, indent=2))
    return 0


if __name__ == '__main__':
    raise SystemExit(main())

#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

WORKSPACE = Path('~/.openclaw/workspace').expanduser()
if str(WORKSPACE) not in sys.path:
    sys.path.insert(0, str(WORKSPACE))

from lib.loop9_automation.config import manual_queue, manual_queue_peek, manual_queue_pop
from lib.loop9_automation.detect import plan_dispatch
from lib.loop9_automation.state import (
    acquire_lock,
    clear_cooldown,
    clear_lock,
    current_cooldown,
    current_lock,
    defer_item,
    release_lock,
    set_cooldown,
)

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description='Thin Loop9 dispatcher helper.')
    sub = parser.add_subparsers(dest='command', required=True)

    plan = sub.add_parser('plan', help='Compute the current dispatch decision for a kind')
    plan.add_argument('kind', choices=['audit', 'poc', 'publish'])
    plan.add_argument('--prefer-run-dir')
    plan.add_argument('--sticky-recovery', action='store_true')
    plan.add_argument('--json', action='store_true')

    claim = sub.add_parser('claim', help='Acquire a per-kind launch/publish lock')
    claim.add_argument('kind', choices=['audit', 'poc', 'publish'])
    claim.add_argument('--candidate', required=True)
    claim.add_argument('--note', default='')
    claim.add_argument('--minutes', type=int)
    claim.add_argument('--meta-json')

    release = sub.add_parser('release', help='Release a per-kind lock')
    release.add_argument('kind', choices=['audit', 'poc', 'publish'])
    release.add_argument('--token')
    release.add_argument('--status', default='released')
    release.add_argument('--note', default='')
    release.add_argument('--meta-json')

    clear = sub.add_parser('clear', help='Force-clear a per-kind lock')
    clear.add_argument('kind', choices=['audit', 'poc', 'publish'])
    clear.add_argument('--note', default='manual-clear')

    show = sub.add_parser('show-lock', help='Show the current lock for a kind')
    show.add_argument('kind', choices=['audit', 'poc', 'publish'])

    defer = sub.add_parser('defer', help='Record a deferred candidate')
    defer.add_argument('kind', choices=['audit', 'poc', 'publish'])
    defer.add_argument('--candidate', required=True)
    defer.add_argument('--reason', required=True)
    defer.add_argument('--meta-json')

    cooldown = sub.add_parser('cooldown-set', help='Set a per-candidate cooldown')
    cooldown.add_argument('kind', choices=['audit', 'poc', 'publish'])
    cooldown.add_argument('--candidate-key', required=True)
    cooldown.add_argument('--reason', required=True)
    cooldown.add_argument('--minutes', type=int)
    cooldown.add_argument('--meta-json')

    cooldown_show = sub.add_parser('cooldown-show', help='Show current cooldown for a candidate')
    cooldown_show.add_argument('kind', choices=['audit', 'poc', 'publish'])
    cooldown_show.add_argument('--candidate-key', required=True)

    cooldown_clear = sub.add_parser('cooldown-clear', help='Clear current cooldown for a candidate')
    cooldown_clear.add_argument('kind', choices=['audit', 'poc', 'publish'])
    cooldown_clear.add_argument('--candidate-key', required=True)
    cooldown_clear.add_argument('--note', default='manual-clear')

    queue_show = sub.add_parser('queue-show', help='Show manualQueue state for a kind')
    queue_show.add_argument('kind', choices=['audit', 'poc'])
    queue_show.add_argument('--json', action='store_true')

    queue_pop = sub.add_parser('queue-pop', help='Pop the head of manualQueue for a kind')
    queue_pop.add_argument('kind', choices=['audit', 'poc'])
    queue_pop.add_argument('--expected-candidate')
    queue_pop.add_argument('--json', action='store_true')

    return parser


def parse_meta(raw: str | None) -> dict:
    if not raw:
        return {}
    return json.loads(raw)


def emit(data: dict, as_json: bool = True) -> None:
    if as_json:
        print(json.dumps(data, ensure_ascii=False, indent=2))
    else:
        for k, v in data.items():
            print(f'{k}={v}')


def main() -> int:
    ns = build_parser().parse_args()
    if ns.command == 'plan':
        plan = plan_dispatch(ns.kind, prefer_run_dir=getattr(ns, 'prefer_run_dir', None), sticky_recovery=getattr(ns, 'sticky_recovery', False)).to_dict()
        emit(plan, as_json=ns.json or True)
        return 0
    if ns.command == 'claim':
        result = acquire_lock(ns.kind, ns.candidate, note=ns.note, minutes=ns.minutes, meta=parse_meta(ns.meta_json))
        emit(result)
        return 0 if result.get('ok') else 2
    if ns.command == 'release':
        result = release_lock(ns.kind, token=ns.token, status=ns.status, note=ns.note, meta=parse_meta(ns.meta_json))
        emit(result)
        return 0 if result.get('ok') else 2
    if ns.command == 'clear':
        emit(clear_lock(ns.kind, note=ns.note))
        return 0
    if ns.command == 'show-lock':
        emit({'lock': current_lock(ns.kind)})
        return 0
    if ns.command == 'defer':
        emit(defer_item(ns.kind, ns.candidate, ns.reason, meta=parse_meta(ns.meta_json)))
        return 0
    if ns.command == 'cooldown-set':
        emit(set_cooldown(ns.kind, ns.candidate_key, ns.reason, minutes=ns.minutes, meta=parse_meta(ns.meta_json)))
        return 0
    if ns.command == 'cooldown-show':
        emit({'cooldown': current_cooldown(ns.kind, ns.candidate_key)})
        return 0
    if ns.command == 'cooldown-clear':
        emit(clear_cooldown(ns.kind, ns.candidate_key, note=ns.note))
        return 0
    if ns.command == 'queue-show':
        emit({'head': manual_queue_peek(ns.kind), 'queue': manual_queue(ns.kind)}, as_json=ns.json or True)
        return 0
    if ns.command == 'queue-pop':
        result = manual_queue_pop(ns.kind, expected_candidate=ns.expected_candidate)
        emit(result, as_json=ns.json or True)
        return 0 if result.get('ok') else 2
    return 1


if __name__ == '__main__':
    raise SystemExit(main())
